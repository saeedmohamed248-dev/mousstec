# ─────────────────────────────────────────────────────────────────────────
# BMW ECU — REAL bench-rig environment (K-Line / KWP2000 via pre-2007 gateway)
# ─────────────────────────────────────────────────────────────────────────
# For the FTDI "K+DCAN" cable + a PRE-03/2007 E-series gateway (E60 / early
# E90) that accepts K-Line/KWP2000 on OBD pin 7 and bridges to PT-CAN.
#
# Copy to `kline_bench.env`, fill every value marked << FILL >>, then:
#     source bmw_ecu/scripts/kline_bench.env
#     python manage.py runserver 0.0.0.0:8000
#
# NOTHING here is guessed. The gateway bridges the frames, but the CAS/DME
# addresses and the CAS-ISN DID/level are PER-PLATFORM and must be the values
# you confirmed from your ZGW / CAS3+ / MEVD17 documentation.

# --- Mode locks -----------------------------------------------------------
# Production hardware LOCK: the simulator can NEVER engage. No interface →
# honest "Hardware Not Found", never fake data.
export BMW_ECU_REQUIRE_HARDWARE=1
unset  BMW_ECU_SIMULATOR

# Where ECU backups are written (must be writable). The used-DME backup taken
# BEFORE any ISN write lands here.
export BMW_ECU_BACKUP_ROOT=/tmp/mousstec_backups

# --- K-Line serial link (the FTDI cable) ----------------------------------
# The blue FTDI cable as a real serial port. Find it after plugging in:
#     ls /dev/cu.usbserial-*        (macOS — e.g. /dev/cu.usbserial-A50285BI)
#     ls /dev/ttyUSB*               (Linux)
export BMW_ECU_KLINE_PORT="<< FILL: e.g. /dev/cu.usbserial-A50285BI >>"

# KWP address of the GATEWAY on pin 7 — the bridge that routes our frames onto
# PT-CAN to the DME and CAS. This is the transport's target.
export BMW_ECU_KLINE_TARGET="<< FILL: gateway KWP address, e.g. 0x?? >>"

# --- Engine-swap (CAS↔DME ISN) addressing — the real E-series Target IDs ---
# These drive RealDmeSwapProvider. CAS and DME diagnostic addresses behind the
# gateway. (Common BMW E-series tester convention is source 0xF1; these are the
# ECU TARGET addresses you read/write — confirm them, do not assume.)
export BMW_ECU_SWAP_CAS_ADDR="<< FILL: CAS3/CAS3+ diagnostic address >>"
export BMW_ECU_SWAP_DME_ADDR="<< FILL: MEVD17 DME diagnostic address >>"

# CONFIRMED CAS ISN access. Until BOTH are set (and confirmed), read_cas_isn
# REFUSES to run — it will not read a guessed DID and call the result an ISN.
export BMW_ECU_SWAP_CAS_ISN_DID="<< FILL: confirmed CAS ISN RDBI DID >>"
export BMW_ECU_SWAP_CAS_ISN_LEVEL="<< FILL: confirmed CAS SecurityAccess level >>"

# CONFIRMED E-series EWS-align RoutineControl ID. The F-series default 0xAF11
# is NOT valid for CAS3 — align_ews refuses until you set the real one.
export BMW_ECU_SWAP_EWS_ROUTINE="<< FILL: confirmed E-series EWS-align routine >>"

# Opt-in safety override: set to 1 ONLY when the DID/level above are the REAL
# confirmed values. Leaving it unset keeps the unverified-spec refusal active.
# export BMW_ECU_SWAP_ALLOW_UNVERIFIED=1

# ─────────────────────────────────────────────────────────────────────────
# NOTE on the MEVD17 (N18) DME ISN WRITE:
#   MEVD17's ISN sits in protected Tricore flash — it is NOT UDS-writable. The
#   write/backup/verify steps route through a dedicated BENCH harness
#   (Xprog / KESS / Trasdata), wired as the provider's `bench=` argument. With
#   no bench harness configured, those steps REFUSE rather than fake a UDS
#   write. The K-Line link above still does the real CAS ISN read + EWS align.
# ─────────────────────────────────────────────────────────────────────────
