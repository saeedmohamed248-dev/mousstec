# ─────────────────────────────────────────────────────────────────────────
# BMW ECU — REAL bench-rig environment (CANable / slcan over D-CAN)
# ─────────────────────────────────────────────────────────────────────────
# Copy to `canable.env`, fill the 3 values marked << FILL >>, then:
#     source bmw_ecu/scripts/canable.env
#     python manage.py runserver 0.0.0.0:8000
#
# Plug-and-play target: when the CANable arrives, you wire it to the OBD
# D-CAN pins (pin 6 = CAN-H, pin 14 = CAN-L, + ground), set the device path
# and the two CAN IDs below, and the live read/code path works. Nothing here
# is guessed — the CAN IDs come from YOUR E-series DME/CAS/ZGW documentation.

# --- Mode locks (the important part) --------------------------------------
# Production hardware LOCK: simulator can NEVER engage, even if a stale
# BMW_ECU_SIMULATOR is left set. No interface → honest "Hardware Not Found".
export BMW_ECU_REQUIRE_HARDWARE=1
unset  BMW_ECU_SIMULATOR

# Where ECU backups are written (must be writable).
export BMW_ECU_BACKUP_ROOT=/tmp/mousstec_backups

# --- CANable / slcan D-CAN link -------------------------------------------
# The CANable shows up as a USB serial device. Find it after plugging in:
#     ls /dev/cu.usbserial-* /dev/cu.usbmodem*      (macOS)
#     ls /dev/ttyACM* /dev/ttyUSB*                  (Linux)
# NOTE: this must be the CANable, NOT the blue FTDI EDIABAS cable
# (/dev/cu.usbserial-A50285BI) — that one is a blind serial pipe, not CAN.
export BMW_ECU_KDCAN_PORT="<< FILL: e.g. /dev/cu.usbmodem-CANABLE >>"
export BMW_ECU_CAN_INTERFACE=slcan          # python-can backend for CANable
export BMW_ECU_CAN_BITRATE=500000           # BMW D-CAN = 500 kbit/s

# Diagnostic CAN IDs — from your E-series documentation. Tester→ECU request
# and ECU→tester response. The defaults shown are the common BMW values but
# MUST be confirmed against the DME/CAS you are addressing through the ZGW.
export BMW_ECU_CAN_TX_ID="<< FILL: e.g. 0x6F1 tester request >>"
export BMW_ECU_CAN_RX_ID="<< FILL: e.g. 0x612 DME response >>"

# --- ENET / DoIP alternative (F/G-series over the ZGW) --------------------
# If you read over ENET instead of D-CAN, set the gateway host and ignore the
# CANable block above. Standard BMW ENET link-local default is 169.254.255.0.
# export BMW_ECU_DOIP_HOST=169.254.255.0
