# =====================================================================
# Mouss Tec ERP — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =====================================================================

# ── Core Django ─────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=False
BASE_DOMAIN=mousstec.com
ADMIN_URL=secure-portal
# Force HTTPS at the application layer when behind a TLS-terminating proxy.
# Leave True in production. Set to False only for local TLS-less debugging.
SECURE_SSL_REDIRECT=True

# ── Database & Cache ────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/mousstec
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS / CSRF (comma-separated) ───────────────────────────────────
CORS_ALLOWED_ORIGINS=https://mousstec.com,https://www.mousstec.com
CSRF_TRUSTED_ORIGINS=https://mousstec.com,https://*.mousstec.com

# ── Email ───────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Mouss Tec <noreply@mousstec.com>
SUPPORT_INBOX_EMAIL=support@mousstec.com

# ── Paymob Payment Gateway ──────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ── Shopify Webhook (HMAC) ──────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=

# ── WhatsApp Business API (OTP delivery) ────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE=otp_login
OTP_DELIVERY_PROVIDER=whatsapp
MARKETPLACE_DEBUG_OTP=False

# ── AI Providers ────────────────────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
GEMINI_API_KEY=
IDEOGRAM_API_KEY=
AI_VISION_API_KEY=
FLUX_MODEL_PROVIDER=together

# ── Feature flags ───────────────────────────────────────────────────
DESIGN_CHAT_ENABLED=True
DESIGN_QUALITY_GATE_ENABLED=True
ENABLE_AI_PREDICTIONS=True

# ── External catalogs ───────────────────────────────────────────────
TECDOC_API_KEY=
ALLDATA_ENDPOINT=

# ── AWS S3 (optional, for media storage) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# ── Sentry ──────────────────────────────────────────────────────────
SENTRY_DSN=
