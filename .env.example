# =====================================================================
# Mouss Tec ERP — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =====================================================================

# ── Core Django ─────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=False
BASE_DOMAIN=mousstec.com
ADMIN_URL=secure-portal
# Force HTTPS at the application layer when behind a TLS-terminating proxy.
# Leave True in production. Set to False only for local TLS-less debugging.
SECURE_SSL_REDIRECT=True

# ── Database & Cache ────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/mousstec
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS / CSRF (comma-separated) ───────────────────────────────────
CORS_ALLOWED_ORIGINS=https://mousstec.com,https://www.mousstec.com
CSRF_TRUSTED_ORIGINS=https://mousstec.com,https://*.mousstec.com

# ── Email ───────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Mouss Tec <noreply@mousstec.com>
SUPPORT_INBOX_EMAIL=support@mousstec.com

# ── Paymob Payment Gateway ──────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ── Shopify Webhook (HMAC) ──────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=

# ── WhatsApp Business API (OTP delivery) ────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE=otp_login
OTP_DELIVERY_PROVIDER=whatsapp
MARKETPLACE_DEBUG_OTP=False

# ── AI Providers ────────────────────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
GEMINI_API_KEY=
IDEOGRAM_API_KEY=
AI_VISION_API_KEY=
FLUX_MODEL_PROVIDER=together

# ── Feature flags ───────────────────────────────────────────────────
DESIGN_CHAT_ENABLED=True
DESIGN_QUALITY_GATE_ENABLED=True
ENABLE_AI_PREDICTIONS=True

# ── External catalogs ───────────────────────────────────────────────
TECDOC_API_KEY=
ALLDATA_ENDPOINT=

# ── AWS S3 (optional, for media storage) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# ── Sentry ──────────────────────────────────────────────────────────
SENTRY_DSN=

# =====================================================================
# BMW / MINI ECU — Used-DME (Engine Swap) ISN alignment
# =====================================================================
# SAFETY POLICY: Mouss Tec never guesses against live hardware. Every
# address / DID / security level below is per-platform and MUST be the
# value YOU confirmed from your ZGW / CAS3(+) / MEVD17 documentation or a
# known-good dump. Leave a value blank and the system REFUSES that step
# (honest 503) instead of inventing one. Hex ("0x40") or decimal both work.
# ---------------------------------------------------------------------

# ── Mode switch ─────────────────────────────────────────────────────
# 1 = dry-run against the in-memory simulator (no hardware, full wizard).
# Unset / 0 = live hardware; the confirmed addresses below become required.
BMW_ECU_SIMULATOR=0
# Set 1 in production to HARD-LOCK the simulator off (belt & suspenders):
# even BMW_ECU_SIMULATOR=1 is ignored, so a real car can never hit a Mock.
BMW_ECU_REQUIRE_HARDWARE=0
# Where encrypted DME/EEPROM backups are written before any ISN write.
BMW_ECU_BACKUP_ROOT=/Users/saied/ERP_System/.ecu_backups

# ── Transport: K-Line bridge through the pre-2007 E-series gateway ───
# The FTDI serial device your K-Line/FTDI cable enumerates as.
BMW_ECU_KLINE_PORT=/dev/cu.usbserial-XXXXXXXX
# KWP diagnostic address of the GATEWAY (ZGW/CAS on pin 7) that bridges
# the OBD frames onto PT-CAN. This is the bridge, NOT the DME.
BMW_ECU_KLINE_TARGET=0x00

# ── E-series diagnostic addresses (REQUIRED for a live run) ─────────-
# Diagnostic address of the CAS3 / CAS3+ immobilizer.
BMW_ECU_SWAP_CAS_ADDR=0x00
# Diagnostic address of the MEVD17 / target DME.
BMW_ECU_SWAP_DME_ADDR=0x12

# ── CAS ISN read spec (confirmed) ───────────────────────────────────
# ReadDataByIdentifier DID that returns the 32-byte ISN from the CAS,
# plus the SecurityAccess level that unlocks it. Both required together
# to read a real ISN; leave blank and the CAS read step refuses.
BMW_ECU_SWAP_CAS_ISN_DID=
BMW_ECU_SWAP_CAS_ISN_LEVEL=

# ── DME ISN write spec — Phase 1 (UDS) (optional) ───────────────────
# WriteDataByIdentifier DID + level for the direct UDS ISN write.
# Provide BOTH to attempt the clean UDS write first. Omit either one and
# Phase 1 is skipped — the pipeline diverts straight to the TriCore BSL
# fallback wizard (Bosch MEVD17 only; Siemens halts to bench/BDM).
BMW_ECU_SWAP_DME_ISN_DID=
BMW_ECU_SWAP_DME_ISN_LEVEL=

# ── EWS alignment (confirmed) ───────────────────────────────────────
# RoutineControl ID for the E-series CAS<->DME EWS-sync routine.
BMW_ECU_SWAP_EWS_ROUTINE=

# ── Safety override ─────────────────────────────────────────────────
# Set 1 ONLY once the DID/level values above are the REAL confirmed ones.
# This opt-in tells the extractor to trust an operator-supplied spec and
# actually run it against the car. Keep 0 until you are certain.
BMW_ECU_SWAP_ALLOW_UNVERIFIED=0

# ── BSL fallback (Phase 2 — no external programmer) ─────────────────-
# FTDI serial device wired STRAIGHT to the DME board's boot pad for
# TriCore Bootstrap-Loader access. Defaults to BMW_ECU_KLINE_PORT if unset.
BMW_ECU_SWAP_BSL_PORT=
